<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Network -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- ❌ REMOVED: REQUEST_INSTALL_PACKAGES
         Reason: AlternativeUpdateManager (APK sideload) remove kar diya gaya.
         Yeh permission Play Store policy violation thi.
         Official In-App Update (InAppUpdateManager) use karo.
    -->

    <!-- AdMob Advertising ID -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID"/>

    <!-- Biometric -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC"/>

    <!-- Android 13+ Notification -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Restart reminder after reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <!-- Storage (Android 9 and below only) -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"/>
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"/>

    <!-- Package visibility -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.SEND"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <package android:name="com.google.android.gms"/>
    </queries>

    <application
        android:name=".SelfAttendanceApp"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.SelfAttendance"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:supportsRtl="true"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:localeConfig="@xml/locales_config">

        <!-- ✅ FIX: AdServices conflict (VERY IMPORTANT) -->
        <property
            android:name="android.adservices.AD_SERVICES_CONFIG"
            android:resource="@xml/gma_ad_services_config"
            tools:replace="android:resource" />

        <!-- AdMob App ID -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-5703232582358249~3516164327"/>

        <!-- Delay measurement -->
        <meta-data
            android:name="com.google.android.gms.ads.DELAY_APP_MEASUREMENT_INIT"
            android:value="true"/>

        <!-- Google Play Services -->
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version"/>

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.SelfAttendance.Splash"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="locale|layoutDirection|fontScale|orientation|screenSize|uiMode">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- Boot Receiver -->
        <receiver
            android:name=".notifications.BootReceiver"
            android:enabled="true"
            android:exported="false">

            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON"/>
            </intent-filter>

        </receiver>

        <!-- FileProvider -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">

            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths"/>

        </provider>

    </application>

</manifest>
