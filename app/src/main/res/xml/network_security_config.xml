<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <!-- Production config: only system CAs trusted, no user certs -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Sirf system-installed CA certificates trust karo -->
            <!-- User-installed certificates deliberately REMOVED (Play Store best practice) -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

</network-security-config>
