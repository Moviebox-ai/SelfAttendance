<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Main App Theme -->
    <style name="Theme.SelfAttendance"
        parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash Screen Theme — Gold background -->
    <style name="Theme.SelfAttendance.Splash"
        parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#F57F17</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.SelfAttendance</item>
    </style>

</resources>
